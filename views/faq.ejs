<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= seo.title %></title>
  <meta name="description" content="<%= seo.description %>">
  <meta name="robots" content="<%= seo.robots %>">
  <link rel="canonical" href="<%= seo.canonical %>">
  <meta name="theme-color" content="#22C55E">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Chess Review">
  <meta name="mobile-web-app-capable" content="yes">
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="icon" href="/images/wN.png" type="image/png">
  <link rel="apple-touch-icon" href="/icons/icon.svg">
  <!-- Open Graph -->
  <meta property="og:title" content="<%= seo.ogTitle %>">
  <meta property="og:description" content="<%= seo.ogDescription %>">
  <meta property="og:url" content="<%= seo.canonical %>">
  <meta property="og:type" content="<%= seo.ogType %>">
  <meta property="og:image" content="<%= seo.ogImage %>">
  <meta property="og:site_name" content="<%= SITE_NAME %>">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= seo.ogTitle %>">
  <meta name="twitter:description" content="<%= seo.ogDescription %>">
  <meta name="twitter:image" content="<%= seo.ogImage %>">
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="/cdn/tailwind"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": "Apakah website ini gratis?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ya, 100% gratis selamanya. Tidak ada iklan, tidak ada batasan jumlah analisis, dan tidak memerlukan akun." }
    }, {
      "@type": "Question",
      "name": "Bagaimana cara kerja analisisnya?",
      "acceptedAnswer": { "@type": "Answer", "text": "Stockfish Engine berjalan langsung di browser kamu melalui Web Worker. Setelah kamu memilih game dari Chess.com, setiap langkah akan dievaluasi dan diklasifikasikan berdasarkan perbandingan dengan langkah terbaik engine." }
    }, {
      "@type": "Question",
      "name": "Apakah data game saya disimpan?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tidak. Data game diambil langsung dari Chess.com API dan hanya diproses di browser kamu. Kami tidak menyimpan data apapun di server." }
    }, {
      "@type": "Question",
      "name": "Menggunakan engine apa?",
      "acceptedAnswer": { "@type": "Answer", "text": "Kami menggunakan Stockfish 10 — salah satu engine catur terkuat di dunia. Dengan analisis depth 10 untuk mendapatkan evaluasi terbaik di setiap posisi." }
    }, {
      "@type": "Question",
      "name": "Apakah mendukung HP/smartphone?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ya, antarmuka kami responsif dan bekerja sempurna di semua perangkat — desktop, tablet, dan smartphone." }
    }, {
      "@type": "Question",
      "name": "Apakah perlu akun Chess.com?",
      "acceptedAnswer": { "@type": "Answer", "text": "Kamu hanya perlu memasukkan username Chess.com untuk mengambil game publik. Tidak perlu login atau memberikan password." }
    }, {
      "@type": "Question",
      "name": "Berapa lama proses analisis?",
      "acceptedAnswer": { "@type": "Answer", "text": "Tergantung panjang permainan. Rata-rata 5-15 detik untuk game 40 langkah. Analisis berjalan otomatis setelah game dipilih." }
    }, {
      "@type": "Question",
      "name": "Apakah bisa digunakan offline?",
      "acceptedAnswer": { "@type": "Answer", "text": "Game diambil dari Chess.com API sehingga koneksi internet diperlukan. Namun engine berjalan di browser, jadi setelah game dimuat, analisis tetap berjalan." }
    }]
  }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #0B1220;
      color: #F8FAFC;
      -webkit-font-smoothing: antialiased;
    }
    ::-webkit-scrollbar { width: 6px; } ::-webkit-scrollbar-track { background: #0B1220; } ::-webkit-scrollbar-thumb { background: #22C55E; border-radius: 3px; }
    ::selection { background: rgba(34,197,94,0.3); }
    .navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 100; transition: all 0.4s ease; padding: 1rem 0; background: rgba(11,18,32,0.75); backdrop-filter: blur(20px) saturate(1.4); border-bottom: 1px solid rgba(255,255,255,0.04); box-shadow: 0 4px 40px rgba(0,0,0,0.3); }
    .nav-link { position: relative; color: rgba(248,250,252,0.6); transition: color 0.3s ease; text-decoration: none; }
    .nav-link::after { content: ''; position: absolute; bottom: -2px; left: 0; width: 0; height: 2px; background: #22C55E; transition: width 0.3s ease; border-radius: 1px; }
    .nav-link:hover { color: #F8FAFC; } .nav-link:hover::after { width: 100%; }
    .btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; background: linear-gradient(135deg, #22C55E, #16a34a); color: white; font-weight: 600; font-family: inherit; padding: 0.75rem 1.75rem; border-radius: 12px; border: none; cursor: pointer; transition: all 0.3s ease; text-decoration: none; }
    .btn-primary:hover { transform: translateY(-2px) scale(1.02); box-shadow: 0 8px 30px rgba(34,197,94,0.25); }
    .faq-item { background: #111827; border: 1px solid rgba(255,255,255,0.04); border-radius: 16px; overflow: hidden; transition: border-color 0.3s ease; }
    .faq-item:hover { border-color: rgba(255,255,255,0.08); } .faq-item.active { border-color: rgba(34,197,94,0.2); }
    .faq-question { width: 100%; display: flex; align-items: center; justify-content: space-between; padding: 1.25rem 1.5rem; background: transparent; border: none; cursor: pointer; color: #F8FAFC; font-size: 1rem; font-weight: 500; text-align: left; font-family: inherit; transition: all 0.3s ease; }
    .faq-question:hover { background: rgba(255,255,255,0.02); }
    .faq-arrow { width: 28px; height: 28px; border-radius: 8px; display: flex; align-items: center; justify-content: center; background: rgba(255,255,255,0.04); flex-shrink: 0; transition: transform 0.4s ease; }
    .faq-item.active .faq-arrow { transform: rotate(180deg); background: rgba(34,197,94,0.15); }
    .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.5s ease; }
    .faq-answer-inner { padding: 0 1.5rem 1.25rem; color: rgba(248,250,252,0.6); font-size: 0.9rem; line-height: 1.7; }
    .bottomBar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
      background: rgba(11,18,32,0.92);
      backdrop-filter: blur(20px) saturate(1.4);
      border-top: 1px solid rgba(255,255,255,0.04);
      padding: 0.5rem 1rem;
      display: none; align-items: center; justify-content: center;
      box-shadow: 0 -4px 30px rgba(0,0,0,0.3);
    }
    .bottomBar-nav { display: flex; align-items: center; gap: 0.75rem; }
    .bottomBar-nav a {
      display: flex; flex-direction: column; align-items: center; gap: 2px;
      padding: 0.35rem 0.7rem; border-radius: 10px; text-decoration: none;
      color: rgba(248,250,252,0.55); font-size: 0.65rem; font-weight: 500;
      transition: all 0.2s ease;
    }
    .bottomBar-nav a i { font-size: 1.05rem; }
    .bottomBar-nav a:hover, .bottomBar-nav a.active { color: #22C55E; background: rgba(34,197,94,0.08); }
    @media (max-width: 767px) { .bottomBar { display: flex; } }
  </style>
</head>
<body>
  <nav class="navbar">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 no-underline" aria-label="Beranda Chess Review">
        <span class="text-2xl" style="line-height:1">♟</span>
        <span class="text-lg font-bold text-[#F8FAFC] tracking-tight">Chess<span class="text-[#22C55E]">Review</span></span>
      </a>
      <div class="hidden md:flex items-center gap-1">
        <a href="/" class="nav-link px-3 py-2 text-sm"><i class="fas fa-home"></i> Home</a>
        <a href="/support" class="nav-link px-3 py-2 text-sm"><i class="fas fa-heart"></i> Support</a>
        <a href="/faq" class="nav-link px-3 py-2 text-sm" style="color:#F8FAFC"><i class="fas fa-question-circle"></i> FAQ</a>
        <a href="/about" class="nav-link px-3 py-2 text-sm"><i class="fas fa-info-circle"></i> About</a>
      </div>
      <a href="/" class="hidden md:inline-flex btn-primary text-sm px-5 py-2.5"><i class="fas fa-play"></i> Start Analysis</a>
    </div>
  </nav>

  <section class="pt-32 pb-28 sm:pb-28">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <span class="inline-block text-xs font-semibold tracking-widest text-[#22C55E] uppercase mb-4">FAQ</span>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-[#F8FAFC] tracking-tight">Frequently Asked <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#22C55E] to-[#16a34a]">Questions</span></h1>
        <p class="text-[rgba(248,250,252,0.4)] text-base mt-4">Pertanyaan yang sering diajukan tentang Chess Game Review</p>
      </div>

      <div class="space-y-3">
        <div class="faq-item active"><button class="faq-question" onclick="toggleFaq(this)"><span>Apakah website ini gratis?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer" style="max-height:80px"><div class="faq-answer-inner">Ya, 100% gratis selamanya. Tidak ada iklan, tidak ada batasan jumlah analisis, dan tidak memerlukan akun.</div></div></div>
        <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Bagaimana cara kerja analisisnya?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer"><div class="faq-answer-inner">Stockfish Engine berjalan langsung di browser kamu melalui Web Worker. Setelah kamu memilih game dari Chess.com, setiap langkah akan dievaluasi dan diklasifikasikan berdasarkan perbandingan dengan langkah terbaik engine.</div></div></div>
        <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Apakah data game saya disimpan?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer"><div class="faq-answer-inner">Tidak. Data game diambil langsung dari Chess.com API dan hanya diproses di browser kamu. Kami tidak menyimpan data apapun di server.</div></div></div>
        <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Menggunakan engine apa?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer"><div class="faq-answer-inner">Kami menggunakan Stockfish 10 — salah satu engine catur terkuat di dunia. Dengan analisis MultiPV depth 10 untuk mendapatkan 3 langkah terbaik di setiap posisi.</div></div></div>
        <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Apakah mendukung HP/smartphone?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer"><div class="faq-answer-inner">Ya, antarmuka kami responsif dan bekerja sempurna di semua perangkat — desktop, tablet, dan smartphone.</div></div></div>
        <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Apakah perlu akun Chess.com?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer"><div class="faq-answer-inner">Kamu hanya perlu memasukkan username Chess.com untuk mengambil game publik. Tidak perlu login atau memberikan password.</div></div></div>
        <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Berapa lama proses analisis?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer"><div class="faq-answer-inner">Tergantung panjang permainan. Rata-rata 5-15 detik untuk game 40 langkah. Analisis berjalan otomatis setelah game dipilih.</div></div></div>
        <div class="faq-item"><button class="faq-question" onclick="toggleFaq(this)"><span>Apakah bisa digunakan offline?</span><span class="faq-arrow"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></span></button><div class="faq-answer"><div class="faq-answer-inner">Tidak untuk saat ini. Karena game diambil dari Chess.com API, koneksi internet diperlukan. Namun engine berjalan di browser, jadi setelah game dimuat, analisis tetap berjalan.</div></div></div>
      </div>

      <div class="text-center mt-12">
        <p class="text-[rgba(248,250,252,0.3)] text-sm">Masih punya pertanyaan? <a href="/" class="text-[#22C55E] hover:underline">Kembali ke Beranda</a></p>
      </div>
    </div>
  </section>

  <footer class="border-t border-[rgba(255,255,255,0.04)] py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <p class="text-[rgba(248,250,252,0.2)] text-xs">Made with <i class="fas fa-heart"></i> &middot; Powered by Stockfish</p>
        <p class="text-[rgba(248,250,252,0.2)] text-xs">&copy; 2024 Chess Review. All rights reserved.</p>
      </div>
    </div>
  </footer>

  <script>
    function toggleFaq(btn) {
      var item = btn.closest('.faq-item');
      var answer = item.querySelector('.faq-answer');
      var isActive = item.classList.contains('active');
      document.querySelectorAll('.faq-item.active').forEach(function(el) { if (el !== item) { el.classList.remove('active'); el.querySelector('.faq-answer').style.maxHeight = '0'; } });
      if (isActive) { item.classList.remove('active'); answer.style.maxHeight = '0'; }
      else { item.classList.add('active'); answer.style.maxHeight = answer.scrollHeight + 'px'; }
    }
    // Open first item by default
    document.addEventListener('DOMContentLoaded', function() {
      var first = document.querySelector('.faq-item.active .faq-answer');
      if (first) first.style.maxHeight = first.scrollHeight + 'px';
    });
  </script>
  <script>if('serviceWorker'in navigator){navigator.serviceWorker.register('/sw.js').catch(function(){})}</script>
  <div class="bottomBar" id="bottomBar"><div class="bottomBar-nav"><a href="/"><i class="fas fa-home"></i><span>Home</span></a><a href="/support"><i class="fas fa-heart"></i><span>Dukung</span></a><a href="/faq" class="active"><i class="fas fa-question-circle"></i><span>FAQ</span></a><a href="/about"><i class="fas fa-info-circle"></i><span>Tentang</span></a></div></div>
<script src="https://crazylatchdisturbance.com/48/af/bf/48afbfae06abba947beed0533c71234f.js"></script>

</body>
</html>
