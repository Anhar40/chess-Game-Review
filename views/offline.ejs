<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= seo.title %></title>
  <meta name="description" content="<%= seo.description %>">
  <meta name="robots" content="<%= seo.robots %>">
  <link rel="canonical" href="<%= seo.canonical %>">
  <meta name="theme-color" content="#0B1220">
  <link rel="icon" href="/images/wN.png" type="image/png">
  <link rel="manifest" href="/manifest.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Lexend:wght@600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: #0B1220;
      color: #F8FAFC;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 2rem 2rem 5rem;
    }
    .container { max-width: 400px; }
    .icon {
      font-size: 4rem;
      color: #22C55E;
      margin-bottom: 1.5rem;
      display: block;
    }
    h1 { font-family: 'Lexend', sans-serif; font-size: 1.5rem; font-weight: 800; margin-bottom: 0.75rem; }
    p { color: rgba(248,250,252,0.55); font-size: 0.95rem; line-height: 1.6; margin-bottom: 2rem; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      background: linear-gradient(135deg, #22C55E, #16a34a);
      color: white; font-weight: 600; font-family: inherit;
      padding: 0.8rem 2rem; border-radius: 12px; border: none;
      cursor: pointer; transition: all 0.25s ease;
      text-decoration: none; font-size: 0.95rem;
    }
    .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(34,197,94,0.28); }
    .btn:active { transform: scale(0.97); }
    .bottomBar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
      background: rgba(11,18,32,0.92);
      backdrop-filter: blur(20px) saturate(1.4);
      border-top: 1px solid rgba(255,255,255,0.04);
      padding: 0.5rem 1rem;
      display: none; align-items: center; justify-content: center;
      box-shadow: 0 -4px 30px rgba(0,0,0,0.3);
    }
    .bottomBar-nav { display: flex; align-items: center; gap: 0.75rem; }
    .bottomBar-nav a {
      display: flex; flex-direction: column; align-items: center; gap: 2px;
      padding: 0.35rem 0.7rem; border-radius: 10px; text-decoration: none;
      color: rgba(248,250,252,0.55); font-size: 0.65rem; font-weight: 500;
      transition: all 0.2s ease;
    }
    .bottomBar-nav a i { font-size: 1.05rem; }
    .bottomBar-nav a:hover, .bottomBar-nav a.active { color: #22C55E; background: rgba(34,197,94,0.08); }
    @media (max-width: 767px) { .bottomBar { display: flex; } }
  </style>
</head>
<body>
  <div class="container">
    <span class="icon">♞</span>
    <h1>Kamu sedang offline</h1>
    <p>Periksa koneksi internet kemudian coba lagi.</p>
    <button class="btn" onclick="window.location.reload()">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
      Coba Lagi
    </button>
  </div>
  <div class="bottomBar" id="bottomBar"><div class="bottomBar-nav"><a href="/"><i class="fas fa-home"></i><span>Home</span></a><a href="/support"><i class="fas fa-heart"></i><span>Dukung</span></a><a href="/faq"><i class="fas fa-question-circle"></i><span>FAQ</span></a><a href="/about"><i class="fas fa-info-circle"></i><span>Tentang</span></a></div></div>
</body>
</html>
