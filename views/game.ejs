  <script src="/cdn/chart.min.js"></script>
  <style>
    body { background-color: #161512; }
    .card { background-color: #1e1e1b; }
    #boardWrap { display: flex; justify-content: center; width: 100%; position: relative; }
    #board { width: 100%; max-width: 480px; position: relative; }
    #board .square-55d63 { box-shadow: none !important; }


    .move-active { background-color: #2b5a2b; border-radius: 4px; }
    .eval-bar-container { width: 20px; background: #333; border-radius: 4px; position: relative; overflow: hidden; flex-shrink: 0; }
    .eval-fill { position: absolute; bottom: 0; left: 0; right: 0; transition: height 0.3s ease; }

    .cls-book { color: #b58863; font-weight: bold; }
    .cls-brilliant { color: #1baaa6; font-weight: bold; }
    .cls-great { color: #5c8bb0; font-weight: bold; }
    .cls-best { color: #81b64c; font-weight: bold; }
    .cls-excellent { color: #81b64c; font-weight: bold; }
    .cls-good { color: #95b776; font-weight: bold; }
    .cls-inaccuracy { color: #e6c34a; font-weight: bold; }
    .cls-mistake { color: #ffa459; font-weight: bold; }
    .cls-blunder { color: #fa412d; font-weight: bold; }
    .cls-missed { color: #fa412d; font-weight: bold; }



    #moveList { max-height: 260px; overflow-y: auto; scrollbar-width: thin; }
    #moveList::-webkit-scrollbar { width: 4px; }
    #moveList::-webkit-scrollbar-track { background: transparent; }
    #moveList::-webkit-scrollbar-thumb { background: #444; border-radius: 2px; }
    .chart-container { position: relative; height: 220px; width: 100%; }
    .piece-417db { cursor: pointer !important; }
    input, select { font-size: 16px; }

    #analysisOverlay {
      position: fixed; inset: 0; z-index: 9999;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px);
      background: rgba(0,0,0,0.55);
      opacity: 0; visibility: hidden;
      transition: opacity 0.4s ease, visibility 0.4s ease;
    }
    #analysisOverlay.show { opacity: 1; visibility: visible; }
    #adRow { margin-bottom: 20px; width: 100%; overflow-x: auto; overflow-y: hidden; -webkit-overflow-scrolling: touch; }
    #container-58377c017129b108965cda8fb76fc4c2 { display: flex !important; flex-direction: row !important; flex-wrap: nowrap !important; gap: 4px; }
    #container-58377c017129b108965cda8fb76fc4c2 > * { flex: 0 0 auto !important; }

    #bottomActionBar {
      position: fixed; bottom: 0; left: 0; right: 0; z-index: 100;
      background: #1e1e1b; border-top: 1px solid #333;
      padding: 8px 16px; padding-bottom: max(8px, env(safe-area-inset-bottom));
    }
    .bar-btn {
      display: flex; flex-direction: column; align-items: center; gap: 2px;
      background: none; border: none; cursor: pointer; padding: 6px 16px;
      color: #9ca3af; transition: color 0.15s;
      font-family: inherit;
    }
    .bar-btn:hover:not(:disabled) { color: #fff; }
    .bar-btn:disabled { color: #4b5563; cursor: default; }
    .bar-btn:active:not(:disabled) { color: #22c55e; }
    .bar-btn-icon { font-size: 24px; line-height: 1; }
    .bar-btn-label { font-size: 10px; }

    .page-content { padding-bottom: 72px; }

    .player-row { display: flex; align-items: center; justify-content: space-between; gap: 8px; padding: 6px 4px; }
    .player-name { font-weight: 600; color: #fff; font-size: 0.95rem; }
    .player-badge { width: 10px; height: 10px; border-radius: 2px; display: inline-block; flex-shrink: 0; }

    .opening-banner { text-align: center; font-size: 0.8rem; color: #b58863; margin-bottom: 4px; min-height: 1.1rem; }
    .player-avatar { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .player-avatar-sm { width: 22px; height: 22px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .accuracy-ring { width: 40px; height: 40px; position: relative; }
    .cls-badge { display: inline-flex; align-items: center; gap: 2px; }

    .highlight-square { position: absolute; pointer-events: none; z-index: 20; border-radius: 0; }
    .highlight-src { background: rgba(255, 213, 0, 0.55); }
    .highlight-dst { background: rgba(255, 213, 0, 0.35); }
    .legal-dot { position: absolute; border-radius: 50%; pointer-events: none; z-index: 25; background: rgba(120, 200, 80, 0.7); }
    .legal-capture { position: absolute; border-radius: 50%; pointer-events: none; z-index: 25; border: 5px solid rgba(120, 200, 80, 0.5); }

    @media (min-width: 640px) {
      .chart-container { height: 250px; }
    }
  </style>
  <script>
    tailwind.config = {
      theme: { extend: { colors: { dark: '#161512', card: '#1e1e1b' } } }
    }
  </script>
