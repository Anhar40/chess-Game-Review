<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
  <title>Analisa Game - Chess.com Analyzer Lite</title>
  <meta name="description" content="Analisis permainan catur dengan Stockfish. Lihat evaluasi langkah demi langkah, deteksi opening, akurasi, dan grafik evaluasi.">
  <meta name="keywords" content="chess, catur, analisis catur, stockfish, chess.com, review game, analisa game catur, evaluasi langkah">
  <meta property="og:title" content="Analisa Game Catur dengan Stockfish">
  <meta property="og:description" content="Analisis permainan catur dengan Stockfish. Evaluasi langkah, akurasi, opening book, dan grafik evaluasi.">
  <meta property="og:type" content="website">
  <meta property="og:image" content="/images/wN.png">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
