  <div id="analysisOverlay">
    <div id="adRow">
      <div id="container-58377c017129b108965cda8fb76fc4c2"><script data-cfasync="false" src="https://crazylatchdisturbance.com/58377c017129b108965cda8fb76fc4c2/invoke.js"></script></div>
    </div>
    <div id="loadingContent" class="text-center">
      <div class="w-14 h-14 border-4 border-green-500 border-t-transparent rounded-full animate-spin mx-auto mb-5"></div>
      <p id="overlayText" class="text-xl text-white font-semibold">Menganalisis permainan...</p>
      <p id="overlaySubtext" class="text-sm text-gray-400 mt-3"></p>
    </div>
  </div>
  <audio id="moveSound" src="/sounds/sound.wav" preload="auto"></audio>
  <script>
    // ============================================================
    // 1. PGN + GAME SETUP
    // ============================================================
    const pgn = <%- pgnJson %>;

    function showFatal(msg) {
      $('#infoContent').html(`<p class="text-red-400">${msg}</p>`);
      $('#statusBadge').text('Error').removeClass('text-gray-400').addClass('text-red-400');
      $('#startAnalysisBtn').prop('disabled', true);
    }

    if (typeof window._chessJsFailed !== 'undefined' && window._chessJsFailed) $('#tpNotice').removeClass('hidden');
    if (typeof Chess === 'undefined') { $('#tpNotice').removeClass('hidden'); showFatal('Gagal memuat chess.js — coba refresh halaman.'); }
    if (typeof Chessboard === 'undefined') $('#tpNotice').removeClass('hidden');

    let chess = null;
    let history = [];
    let totalMoves = 0;
    let fens = [];
    let header = {};
    let pgnValid = false;

    if (typeof Chess !== 'undefined') {
      try {
        chess = new Chess();
        if (!chess.load_pgn(pgn, { sloppy: true })) throw new Error('load_pgn returned false');

        history = chess.history({ verbose: true });
        totalMoves = history.length;

        const navChess = new Chess();
        fens = [navChess.fen()];
        for (const move of history) {
          navChess.move(move.san, { sloppy: true });
          fens.push(navChess.fen());
        }
        header = chess.header();
        pgnValid = true;
      } catch (e) {
        console.error('PGN parse error:', e);
        showFatal('PGN tidak valid atau tidak didukung.');
      }
    }

    if (!pgnValid) { history = []; totalMoves = 0; fens = ['start']; header = {}; }

    const whiteName = header.White || 'Putih';
    const blackName = header.Black || 'Hitam';
    const whiteElo = header.WhiteElo || '';
    const blackElo = header.BlackElo || '';
    const result = header.Result || '*';
    const date = header.Date || header.UTCDate || '-';
    const event = header.Event || 'Game';
    const eco = header.ECO || '-';

    function escapeHtml(str) {
      return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    let boardOrientation = 'white';
    let whiteAvatarUrl = '', blackAvatarUrl = '';

    function fetchPlayerProfile(username, isWhite) {
      if (!username || username === 'Putih' || username === 'Hitam') return;
      const key = isWhite ? 'white' : 'black';
      $.getJSON(`/api/proxy/player/${encodeURIComponent(username)}`)
        .done(data => {
          if (data.avatar) {
            if (isWhite) whiteAvatarUrl = data.avatar;
            else blackAvatarUrl = data.avatar;
            updateAvatarDisplay();
          }
        })
        .fail(() => {});
    }

    function updateAvatarDisplay() {
      const $ba = $('#bottomPlayerAvatar'), $ta = $('#topPlayerAvatar');
      if (whiteAvatarUrl) $('#infoWhiteAvatar').attr('src', whiteAvatarUrl).removeClass('hidden');
      if (blackAvatarUrl) $('#infoBlackAvatar').attr('src', blackAvatarUrl).removeClass('hidden');
      const isFlipped = boardOrientation === 'black';
      const bottomUrl = isFlipped ? blackAvatarUrl : whiteAvatarUrl;
      const topUrl = isFlipped ? whiteAvatarUrl : blackAvatarUrl;
      if (bottomUrl) { $ba.attr('src', bottomUrl).removeClass('hidden'); } else { $ba.addClass('hidden'); }
      if (topUrl) { $ta.attr('src', topUrl).removeClass('hidden'); } else { $ta.addClass('hidden'); }
    }

    if (pgnValid) {
      fetchPlayerProfile(whiteName, true);
      fetchPlayerProfile(blackName, false);

      $('#infoContent').html(`
        <div class="flex items-center gap-2"><span class="text-green-400 font-semibold">Putih:</span><img id="infoWhiteAvatar" class="player-avatar-sm hidden" alt=""><span class="text-white">${escapeHtml(whiteName)}</span></div>
        <div class="flex items-center gap-2"><span class="text-blue-400 font-semibold">Hitam:</span><img id="infoBlackAvatar" class="player-avatar-sm hidden" alt=""><span class="text-white">${escapeHtml(blackName)}</span></div>
        <div class="flex items-center gap-2"><span class="text-gray-400">Hasil:</span><span class="text-white font-bold">${escapeHtml(result)}</span></div>
        <div class="flex items-center gap-2"><span class="text-gray-400">Tanggal:</span><span class="text-white">${escapeHtml(date)}</span></div>
        <div class="flex items-center gap-2"><span class="text-gray-400">Event:</span><span class="text-white">${escapeHtml(event)}</span></div>
        <div class="flex items-center gap-2"><span class="text-gray-400">ECO:</span><span class="text-white">${escapeHtml(eco)}</span></div>
        <div class="flex items-center gap-2"><span class="text-gray-400">Jumlah langkah:</span><span class="text-white">${totalMoves}</span></div>
      `);
    }

    boardOrientation = 'white';
    swapPlayerDisplay();

    // ============================================================
    // 2. OPENING BOOK (loaded from server: data/openings.json)
    // ============================================================
    let openingsBook = [];
    let bookPlies = [];
    let currentOpeningName = '';

    function findLongestOpeningMatch(sanList) {
      let best = null;
      for (const o of openingsBook) {
        if (o.moves.length < sanList.length) continue;
        let match = true;
        for (let i = 0; i < sanList.length; i++) {
          if (o.moves[i] !== sanList[i]) { match = false; break; }
        }
        if (match && (!best || o.moves.length > best.moves.length)) best = o;
      }
      return best;
    }

    function computeBookPlies() {
      const plies = [];
      const sanSoFar = [];
      for (let ply = 0; ply <= totalMoves; ply++) {
        const match = findLongestOpeningMatch(sanSoFar);
        plies[ply] = match && sanSoFar.length > 0
          ? { eco: match.eco, name: match.name }
          : null;
        if (ply < totalMoves) sanSoFar.push(history[ply].san);
      }
      return plies;
    }

    function extractOpeningParts(fullName) {
      const idx = fullName.indexOf(': ');
      if (idx === -1) return { opening: fullName, variation: '' };
      return { opening: fullName.slice(0, idx), variation: fullName.slice(idx + 2) };
    }

    function loadOpeningsBook() {
      return fetch('/api/openings')
        .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(data => {
          openingsBook = Array.isArray(data) ? data : [];
          if (pgnValid) bookPlies = computeBookPlies();
        })
        .catch(err => {
          console.warn('Opening book unavailable:', err.message);
          openingsBook = [];
          bookPlies = [];
        });
    }
    const openingsReady = loadOpeningsBook();

    function updateOpeningInfo(ply) {
      const $card = $('#openingInfoCard');
      const $banner = $('#openingBanner');
      const bookInfo = bookPlies[ply];
      if (bookInfo) {
        const parts = extractOpeningParts(bookInfo.name);
        $banner.text(`${bookInfo.eco} — ${bookInfo.name}`);
        $('#openingNameDisplay').text(parts.opening);
        $('#openingVariationDisplay').text(parts.variation);
        $('#openingEcoDisplay').text(`ECO: ${bookInfo.eco}`);
        $card.removeClass('hidden');
        currentOpeningName = `${bookInfo.eco} — ${bookInfo.name}`;
      } else {
        let prevName = '';
        for (let p = ply - 1; p >= 0; p--) {
          if (bookPlies[p]) { prevName = bookPlies[p].eco ? `${bookPlies[p].eco} — ${bookPlies[p].name}` : bookPlies[p].name; break; }
        }
        $banner.text(prevName);
        $card.addClass('hidden');
        currentOpeningName = prevName;
      }
    }

    // ============================================================
    // 3. BOARD + NAVIGATION (responsive sizing)
    // ============================================================
    let currentPly = 0;
    let board = null;
    let _suggestionFromNext = false;

    function computeBoardWidth() {
      const wrap = document.getElementById('boardWrap');
      const wrapWidth = wrap ? wrap.clientWidth : window.innerWidth;
      const evalBarWidth = 28;
      const available = wrapWidth - evalBarWidth;
      return Math.max(220, Math.min(480, available));
    }

    function initBoard() {
      if (typeof Chessboard === 'undefined') {
        $('#board').html('<p class="text-red-400 p-4 text-sm">Gagal memuat chessboard.js. Coba refresh halaman.</p>');
        return;
      }
      try {
        board = Chessboard('board', {
          position: pgnValid ? fens[0] : 'start',
          pieceTheme: '/images/{piece}.png',
          boardWidth: computeBoardWidth(),
          draggable: pgnValid,
          onDragStart: pgnValid ? onUserDragStart : null,
          onDrop: pgnValid ? onUserDrop : null,
          onSnapEnd: onUserSnapEnd,
        });
        // Chessboard replaces #board content, re-create the arrow SVG overlay
        if (!$('#boardArrowLayer').length) {
          $('#board').append('<svg id="boardArrowLayer" xmlns="http://www.w3.org/2000/svg" style="position: absolute; top: 0; left: 0; pointer-events: none; z-index: 50;"></svg>');
        }
        positionArrowLayer();
        setupClickToMove();
      } catch (e) {
        console.error('Chessboard init error:', e);
        $('#board').html('<p class="text-red-400 p-4 text-sm">Gagal memuat papan catur.</p>');
      }
    }
    initBoard();

    function positionArrowLayer() {
      const $boardEl = $('#board');
      const w = $boardEl.width();
      const $svg = $('#boardArrowLayer');
      if (!$svg.length) return;
      $svg.attr('width', w).attr('height', w).attr('viewBox', `0 0 ${w} ${w}`);
      $svg.css({ width: w + 'px', height: w + 'px' });
    }

    let resizeTimer = null;
    $(window).on('resize orientationchange', function() {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        if (board) {
          board.resize();
          const fen = (_userPlyOff > 0) ? userMoveStack[_userPlyOff - 1].fen : (pgnValid ? fens[currentPly] : 'start');
          board.position(fen, false);
          positionArrowLayer();
          drawSuggestionArrow();
          drawSquareBadge(currentPly);
        }
      }, 150);
    });

    // ============================================================
    // 4. MOVE CLASSIFICATION (chess.com style)
    // ============================================================
    const MOVE_ICONS = {
      book:        { icon: '📖', label: 'Book', cls: 'cls-book' },
      brilliant:   { icon: '!!', label: 'Brilliant', cls: 'cls-brilliant' },
      great:       { icon: '!',  label: 'Great', cls: 'cls-great' },
      best:        { icon: '★',  label: 'Best', cls: 'cls-best' },
      excellent:   { icon: '👍', label: 'Excellent', cls: 'cls-excellent' },
      good:        { icon: '✔', label: 'Good', cls: 'cls-good' },
      inaccuracy:  { icon: '?!', label: 'Inaccuracy', cls: 'cls-inaccuracy' },
      mistake:     { icon: '?',  label: 'Mistake', cls: 'cls-mistake' },
      blunder:     { icon: '??', label: 'Blunder', cls: 'cls-blunder' },
      missed:      { icon: '❌', label: 'Missed Win', cls: 'cls-missed' },
    };

    let classifications = [];
    let bestMoves = [];
    const PIECE_VALUES = { p: 1, n: 3, b: 3, r: 5, q: 9, k: 0 };

    function isUserBrilliant(fenBefore, move, evalScore) {
      if (Math.abs(evalScore) >= 900) return false;
      if (!move || !move.from || !move.to) return false;

      const c = new Chess();
      c.load(fenBefore);

      // Not forced
      if (c.moves({ verbose: true }).length <= 1) return false;

      try { c.move(move.san, { sloppy: true }); } catch (e) { return false; }

      const destPiece = c.get(move.to);
      if (!destPiece) return false;
      const movedValue = PIECE_VALUES[destPiece.type] || 0;

      // Check if opponent can capture our piece
      let totalSacLoss = 0;
      const oppMoves = c.moves({ verbose: true });

      function checkSacU(capFen, capSan) {
        const ck = new Chess(capFen);
        try { ck.move(capSan, { sloppy: true }); } catch (e) { return 0; }
        let bestR = 0;
        for (const ourM of ck.moves({ verbose: true })) {
          if (ourM.to === move.to && ourM.captured) bestR = Math.max(bestR, PIECE_VALUES[ourM.captured] || 0);
        }
        const nLoss = movedValue - bestR;
        return (movedValue >= 3 && nLoss > 0) ? nLoss : 0;
      }

      // 1) Direct capture
      for (const oppMove of oppMoves) {
        if (oppMove.to === move.to && oppMove.captured) {
          totalSacLoss = Math.max(totalSacLoss, checkSacU(c.fen(), oppMove.san));
        }
      }

      // 2) Capture after check sequence
      if (totalSacLoss <= 0) {
        for (const oppMove of oppMoves) {
          if (oppMove.to === move.to || oppMove.captured) continue;
          const cTemp = new Chess(c.fen());
          try { cTemp.move(oppMove.san, { sloppy: true }); } catch (e) { continue; }
          if (!cTemp.in_check()) continue;
          const replies = cTemp.moves({ verbose: true });
          if (replies.length !== 1) continue;
          cTemp.move(replies[0].san, { sloppy: true });
          for (const nextOpp of cTemp.moves({ verbose: true })) {
            if (nextOpp.to === move.to && nextOpp.captured) {
              totalSacLoss = Math.max(totalSacLoss, checkSacU(cTemp.fen(), nextOpp.san));
            }
          }
          if (totalSacLoss > 0) break;
        }
      }

      return totalSacLoss > 0;
    }

    function isBrilliant(ply, evalBefore, evalAfterPlayed, loss) {
      if (Math.abs(evalBefore) >= 900) return false;

      const move = history[ply - 1];
      if (!move || !move.from || !move.to) return false;

      const c = new Chess();
      const fenBefore = fens[ply - 1];
      if (!fenBefore) return false;
      c.load(fenBefore);

      // Not forced — must have at least 2 legal moves
      const allMoves = c.moves({ verbose: true });
      if (allMoves.length <= 1) return false;

      // Not a direct recapture (capturing on same square opponent just captured from)
      if (ply >= 2) {
        const prevMove = history[ply - 2];
        if (prevMove && prevMove.captured && move.to === prevMove.to) return false;
      }

      const inCheck = c.in_check();

      // Make the move to see the resulting position
      try { c.move(move.san, { sloppy: true }); } catch (e) { return false; }

      const destPiece = c.get(move.to);
      if (!destPiece) return false;
      const movedType = destPiece.type;
      const movedValue = PIECE_VALUES[movedType] || 0;

      // Sacrifice detection: check if opponent can capture our moved piece
      let totalSacrificeLoss = 0;
      const oppMoves = c.moves({ verbose: true });

      function checkSacrifice(captureFen, captureMoveSan) {
        const ck = new Chess(captureFen);
        try { ck.move(captureMoveSan, { sloppy: true }); } catch (e) { return 0; }
        let bestRecap = 0;
        for (const ourMove of ck.moves({ verbose: true })) {
          if (ourMove.to === move.to && ourMove.captured) {
            bestRecap = Math.max(bestRecap, PIECE_VALUES[ourMove.captured] || 0);
          }
        }
        const netLoss = movedValue - (PIECE_VALUES[move.captured] || 0) - bestRecap;
        return (movedValue >= 3 && netLoss > 0) ? netLoss : 0;
      }

      // 1) Direct capture in next ply
      for (const oppMove of oppMoves) {
        if (oppMove.to === move.to && oppMove.captured) {
          totalSacrificeLoss = Math.max(totalSacrificeLoss, checkSacrifice(c.fen(), oppMove.san));
        }
      }

      // 2) Opponent check + forced response enables the capture later
      if (totalSacrificeLoss <= 0) {
        for (const oppMove of oppMoves) {
          if (oppMove.to === move.to || oppMove.captured) continue;
          const cTemp = new Chess(c.fen());
          try { cTemp.move(oppMove.san, { sloppy: true }); } catch (e) { continue; }
          if (!cTemp.in_check()) continue;
          const ourReplies = cTemp.moves({ verbose: true });
          if (ourReplies.length !== 1) continue;
          cTemp.move(ourReplies[0].san, { sloppy: true });
          for (const nextOpp of cTemp.moves({ verbose: true })) {
            if (nextOpp.to === move.to && nextOpp.captured) {
              totalSacrificeLoss = Math.max(totalSacrificeLoss, checkSacrifice(cTemp.fen(), nextOpp.san));
            }
          }
          if (totalSacrificeLoss > 0) break;
        }
      }

      if (totalSacrificeLoss <= 0) return false;

      // Position stays favorable (not worse than -100cp for the mover)
      const evalForMover = (ply % 2 === 1) ? evalAfterPlayed : -evalAfterPlayed;
      if (evalForMover < -100) return false;

      // If was in check, ensure position doesn't become losing
      if (inCheck && evalForMover < -100) return false;

      return true;
    }

    function classifyMove(ply, evalBefore, evalAfterPlayed, evalAfterBest, isMissedWin) {
      if (bookPlies[ply]) return 'book';

      const isWhiteMove = (ply % 2 === 1);
      const bestForMover = isWhiteMove ? evalAfterBest : -evalAfterBest;
      const playedForMover = isWhiteMove ? evalAfterPlayed : -evalAfterPlayed;
      const loss = bestForMover - playedForMover;
      const bm = bestMoves[ply - 1];
      const playedBestMove = bm && bm.isPlayedMove;

      if (isMissedWin) return 'missed';
      if (isBrilliant(ply, evalBefore, evalAfterPlayed, loss)) return 'brilliant';
      if (playedBestMove) {
        const improvement = isWhiteMove ? (evalAfterPlayed - evalBefore) : (evalBefore - evalAfterPlayed);
        if (improvement >= 50) return 'great';
        return 'best';
      }

      if (loss <= 30) return 'excellent';
      if (loss <= 110) return 'good';
      if (loss <= 280) return 'inaccuracy';
      if (loss <= 530) return 'mistake';
      return 'blunder';
    }

    function renderMoveList(ply, hideLabels) {
      const $list = $('#moveList');
      if (!pgnValid) { $list.html(''); return; }
      let html = '';
      const showBadges = !hideLabels;
      for (let i = 0; i < totalMoves; i += 2) {
        const moveNum = Math.floor(i / 2) + 1;
        const whiteMove = history[i];
        const blackMove = history[i + 1];
        const whitePly = i + 1;
        const blackPly = i + 2;

        const wInfo = showBadges ? classifications[whitePly] : null;
        const bInfo = showBadges ? classifications[blackPly] : null;
        const wBadge = wInfo ? `<span class="${wInfo.cls}" title="${wInfo.label}">${wInfo.icon}</span>` : '';
        const bBadge = bInfo ? `<span class="${bInfo.cls}" title="${bInfo.label}">${bInfo.icon}</span>` : '';

        html += `<div class="move-entry ${ply === whitePly ? 'move-active' : ''}" data-ply="${whitePly}">
          <span class="text-gray-500">${moveNum}.</span>
          <span class="move-text ${wInfo ? wInfo.cls : ''} cursor-pointer hover:text-green-400" data-ply="${whitePly}">${whiteMove ? escapeHtml(whiteMove.san) : ''} ${wBadge}</span>
          <span class="move-text ${bInfo ? bInfo.cls : ''} cursor-pointer hover:text-green-400" data-ply="${blackPly}">${blackMove ? escapeHtml(blackMove.san) : ''} ${bBadge}</span>
        </div>`;
      }
      $list.html(html);

      $list.find('.move-text').on('click', function(e) {
        e.stopPropagation();
        const p = parseInt($(this).data('ply'));
        if (!isNaN(p)) navToPly(p);
      });
      $list.find('.move-entry').on('click', function() {
        const p = parseInt($(this).data('ply'));
        if (!isNaN(p)) navToPly(p);
      });
    }

    function updateMoveClassifyCallout(ply) {
      const $c = $('#moveClassifyCallout');
      const info = classifications[ply];
      $c.css('background', '');
      if (!info || ply === 0) { $c.addClass('hidden'); return; }
      const bgMap = {
        book: 'bg-[#b58863]/20 text-[#b58863]',
        brilliant: 'bg-[#1baaa6]/20 text-[#1baaa6]',
        great: 'bg-[#5c8bb0]/20 text-[#5c8bb0]',
        best: 'bg-[#81b64c]/20 text-[#81b64c]',
        excellent: 'bg-[#81b64c]/20 text-[#81b64c]',
        good: 'bg-[#95b776]/20 text-[#95b776]',
        inaccuracy: 'bg-[#e6c34a]/20 text-[#e6c34a]',
        mistake: 'bg-[#ffa459]/20 text-[#ffa459]',
        blunder: 'bg-[#fa412d]/20 text-[#fa412d]',
        missed: 'bg-[#fa412d]/20 text-[#fa412d]',
      };
      const move = history[ply - 1];
      $c.removeClass().addClass(`text-center py-2 px-3 rounded-lg mt-1 text-sm font-semibold ${bgMap[info.type] || ''}`);
      $c.text(`${move ? move.san : ''}  ${info.icon}  ${info.label}`);
    }

    const BADGE_COLORS = {
      book: '#b58863', brilliant: '#1baaa6', great: '#5c8bb0', best: '#81b64c',
      excellent: '#81b64c', good: '#95b776', inaccuracy: '#e6c34a',
      mistake: '#ffa459', blunder: '#fa412d', missed: '#fa412d'
    };

    function drawSquareBadge(ply) {
      $('#squareBadgeOverlay').remove();
      if (ply === 0) return;
      const info = classifications[ply];
      if (!info) return;
      const move = history[ply - 1];
      if (!move || !move.to) return;
      const $board = $('#board');
      if (!$board.length) return;
      const cell = $board.width() / 8;
      const file = FILES.indexOf(move.to[0]);
      const rank = parseInt(move.to[1], 10);
      const boardPos = $board.position();
      const size = Math.max(22, cell * 0.55);
      const badgeLeft = boardPos.left + (boardOrientation === 'black' ? (7 - file) : file) * cell + cell * 0.5;
      const badgeTop = boardPos.top + (boardOrientation === 'black' ? (rank - 1) : (8 - rank)) * cell + cell * 0.32;
      const $badge = $('<div>', { id: 'squareBadgeOverlay' }).css({
        position: 'absolute',
        left: badgeLeft + 'px',
        top: badgeTop + 'px',
        width: size, height: size, borderRadius: '50%',
        backgroundColor: BADGE_COLORS[info.type] || '#666',
        border: '2px solid #111', zIndex: 100,
        display: 'flex', alignItems: 'center', justifyContent: 'center',
        fontSize: Math.max(11, cell * 0.3) + 'px',
        fontWeight: 'bold', color: '#fff', pointerEvents: 'none',
        transform: 'translate(-50%, -50%)',
        textShadow: '0 0 3px rgba(0,0,0,0.9)'
      }).text(info.icon);
      $('#boardWrap').append($badge);
    }

    // ============================================================
    // 5. SUGGESTION ARROW
    // ============================================================
    const FILES = ['a','b','c','d','e','f','g','h'];

    function squareToXY(square, boardWidthPx) {
      const cell = boardWidthPx / 8;
      const file = FILES.indexOf(square[0]);
      const rank = parseInt(square[1], 10);
      const x = (boardOrientation === 'black' ? (7 - file) : file) * cell + cell / 2;
      const y = (boardOrientation === 'black' ? (rank - 1) : (8 - rank)) * cell + cell / 2;
      return { x, y };
    }

    function drawSuggestionArrow() {
      if (_userPlyOff === 0 && !_suggestionFromNext && !window._userSuggestion) return;
      if (_userPlyOff === 0 && bookPlies[currentPly] && !window._userSuggestion) return;
      const $svg = $('#boardArrowLayer');
      if (!$svg.length) return;
      $svg.find('.arrow-group').remove();
      if (!$('#arrowToggle').is(':checked')) return;

      const suggestion = (_userPlyOff > 0 ? window._userSuggestion : null)
        || (currentPly > 0 ? bestMoves[currentPly - 1] : bestMoves[0]);
      if (!suggestion || !suggestion.from || !suggestion.to) return;
      // Don't show if the played move was already engine's best move
      if (_userPlyOff === 0 && suggestion.isPlayedMove) return;

      const boardWidthPx = $('#board').width();
      const ns = 'http://www.w3.org/2000/svg';
      const group = document.createElementNS(ns, 'g');
      group.setAttribute('class', 'arrow-group');

      const defs = document.createElementNS(ns, 'defs');
      const marker = document.createElementNS(ns, 'marker');
      marker.setAttribute('id', 'arrowhead');
      marker.setAttribute('markerWidth', '4');
      marker.setAttribute('markerHeight', '4');
      marker.setAttribute('refX', '2');
      marker.setAttribute('refY', '2');
      marker.setAttribute('orient', 'auto');
      const poly = document.createElementNS(ns, 'polygon');
      poly.setAttribute('points', '0,0 4,2 0,4');
      poly.setAttribute('fill', 'rgba(255, 170, 0, 0.9)');
      marker.appendChild(poly);
      defs.appendChild(marker);
      group.appendChild(defs);

      const from = squareToXY(suggestion.from, boardWidthPx);
      const to = squareToXY(suggestion.to, boardWidthPx);

      const line = document.createElementNS(ns, 'line');
      line.setAttribute('x1', from.x);
      line.setAttribute('y1', from.y);
      line.setAttribute('x2', to.x);
      line.setAttribute('y2', to.y);
      line.setAttribute('stroke', 'rgba(255, 170, 0, 0.75)');
      line.setAttribute('stroke-width', Math.max(2, boardWidthPx / 80));
      line.setAttribute('marker-end', 'url(#arrowhead)');
      line.setAttribute('stroke-linecap', 'round');
      group.appendChild(line);

      $svg[0].appendChild(group);
    }

    // ============================================================
    // 6. SOUND
    // ============================================================
    function playMoveSound() {
      if (!$('#soundToggle').is(':checked')) return;
      const audio = document.getElementById('moveSound');
      if (!audio) return;
      try {
        audio.currentTime = 0;
        audio.play().catch(() => {});
      } catch (e) {}
    }

    // ============================================================
    // 7. NAVIGATION (including user custom moves)
    // ============================================================
    function clearUserHighlights() {
      selectedSquare = null;
      userFen = null;
      userSanList = [];
      userMoveStack = [];
      _userPlyOff = 0;
      _userMoveBasePly = 0;
      window._userSuggestion = null;
      $('#board').find('.highlight-square, .legal-dot, .legal-capture, .pv-badge').remove();
    }

    function totalPlies() { return totalMoves + userMoveStack.length; }

    function showPosition(playSound) {
      if (!board || !pgnValid) return;
      const isUserMove = _userPlyOff > 0;
      const ply = currentPly + _userPlyOff;

      if (isUserMove) {
        const entry = userMoveStack[_userPlyOff - 1];
        board.position(entry.fen);
      } else {
        board.position(fens[currentPly]);
      }

      $('#moveCounter').text(`${ply} / ${totalMoves}`);
      renderMoveList(ply, isUserMove);
      updateOpeningInfo(currentPly);
      syncBottomBar();

      // Draw suggestion arrow
      drawSuggestionArrow();

      // Clear board overlays (highlights/badges) then re-draw
      $('#board').find('.highlight-square, .legal-dot, .legal-capture, .pv-badge').remove();
      $('#squareBadgeOverlay').remove();

      if (isUserMove) {
        const entry = userMoveStack[_userPlyOff - 1];
        highlightLastMove(entry);
        // Show classification callout
        const meta = MOVE_ICONS[entry.type] || MOVE_ICONS.good;
        $('#moveClassifyCallout').removeClass('hidden')
          .html(`<span class="${meta.cls}">${entry.san}  ${meta.icon}  ${meta.label}</span>`)
          .css('background', 'rgba(30,30,27,0.9)');
        // Show badge on moved piece
        const sanSeq = [];
        for (let i = 0; i < currentPly; i++) sanSeq.push(history[i].san);
        for (let i = 0; i < userMoveStack.length; i++) sanSeq.push(userMoveStack[i].san);
        const bookMatch = findLongestOpeningMatch(sanSeq);
        showMultiPvIcons(entry.to, entry.type, !!(bookMatch && bookMatch.moves.length >= sanSeq.length));
        // Evaluation bar for user moves
        updateEvalBar(entry.score);
      } else {
        window._userSuggestion = null;
        highlightLastMove(ply > 0 && ply <= totalMoves ? history[ply - 1] : null);
        updateMoveClassifyCallout(ply);
        drawSquareBadge(ply);
        const evals = window.evaluations || [];
        updateEvalBar(evals[currentPly] !== undefined ? evals[currentPly] : null);
      }

      if (playSound !== false) playMoveSound();
    }

    function highlightLastMove(move) {
      clearLegalHighlights();
      if (move && move.from) highlightSquare(move.from, 'highlight-src');
      if (move && move.to) highlightSquare(move.to, 'highlight-dst');
    }

    function navPrev(playSound) {
      if (!pgnValid) return;
      if (currentPly <= 0) return;
      currentPly--;
      _userPlyOff = 0;
      _suggestionFromNext = false;
      showPosition(playSound);
    }

    function navNext(playSound) {
      if (!pgnValid) return;
      const cur = currentPly + _userPlyOff;
      if (cur >= totalMoves) return;
      const nextPly = cur + 1;
      currentPly = nextPly; _userPlyOff = 0;
      _suggestionFromNext = true;
      showPosition(playSound);
    }

    function navFirst(playSound) {
      if (!pgnValid) return;
      const changed = currentPly > 0 || _userPlyOff > 0;
      currentPly = 0; _userPlyOff = 0;
      _suggestionFromNext = false;
      if (changed) showPosition(playSound);
    }

    function navLast(playSound) {
      if (!pgnValid) return;
      const was = currentPly + _userPlyOff;
      currentPly = totalMoves; _userPlyOff = 0;
      _suggestionFromNext = false;
      if (currentPly !== was) showPosition(playSound);
    }

    function navToPly(ply, playSound) {
      if (!pgnValid) return;
      if (ply < 0) ply = 0;
      if (ply > totalMoves) ply = totalMoves;
      const was = currentPly + _userPlyOff;
      currentPly = ply;
      _userPlyOff = 0;
      clearUserHighlights();
      _suggestionFromNext = false;
      if (currentPly !== was) showPosition(playSound);
    }

    // Re-bind navigation event handlers
    function bindNavButtons() {
      $('#firstBtn').off().on('click', () => navFirst());
      $('#prevBtn').off().on('click', () => navPrev());
      $('#nextBtn').off().on('click', () => navNext());
      $('#lastBtn').off().on('click', () => navLast());
      $('#barPrevBtn').off().on('click', () => navPrev());
      $('#barNextBtn').off().on('click', () => navNext());
      $('#barRotateBtn').off().on('click', rotateBoard);
    }

    function syncBottomBar() {
      const ply = currentPly + _userPlyOff;
      const total = totalMoves + userMoveStack.length;
      $('#barPrevBtn').prop('disabled', ply <= 0);
      $('#barNextBtn').prop('disabled', ply >= total);
    }

    function swapPlayerDisplay() {
      const isFlipped = boardOrientation === 'black';
      const bottomName = isFlipped ? blackName : whiteName;
      const topName = isFlipped ? whiteName : blackName;
      const bottomElo = isFlipped ? blackElo : whiteElo;
      const topElo = isFlipped ? whiteElo : blackElo;
      const bottomAvatar = isFlipped ? blackAvatarUrl : whiteAvatarUrl;
      const topAvatar = isFlipped ? whiteAvatarUrl : blackAvatarUrl;

      $('#bottomPlayerName').text(bottomName);
      $('#bottomPlayerMeta').text(bottomElo ? `(${bottomElo})` : '');
      $('#topPlayerName').text(topName);
      $('#topPlayerMeta').text(topElo ? `(${topElo})` : '');

      const $ba = $('#bottomPlayerAvatar');
      const $ta = $('#topPlayerAvatar');
      if (bottomAvatar) { $ba.attr('src', bottomAvatar).removeClass('hidden'); } else { $ba.addClass('hidden'); }
      if (topAvatar) { $ta.attr('src', topAvatar).removeClass('hidden'); } else { $ta.addClass('hidden'); }
    }

    function rotateBoard() {
      if (!board) return;
      boardOrientation = boardOrientation === 'white' ? 'black' : 'white';
      board.orientation(boardOrientation);
      swapPlayerDisplay();
      positionArrowLayer();
      drawSuggestionArrow();
      drawSquareBadge(currentPly);
      const evals = window.evaluations || [];
      updateEvalBar(evals[currentPly] !== undefined ? evals[currentPly] : null);
      // Reposition overlays after rotation
      if (selectedSquare) {
        showLegalMoves(selectedSquare);
      }
    }

    bindNavButtons();
    $('#arrowToggle').on('change', drawSuggestionArrow);

    $(document).on('keydown', function(e) {
      if (e.target.tagName === 'INPUT' || e.target.tagName === 'SELECT') return;
      if (e.key === 'ArrowLeft') navPrev();
      if (e.key === 'ArrowRight') navNext();
      if (e.key === 'Home') navFirst();
      if (e.key === 'End') navLast();
    });

    (function enableSwipe() {
      const el = document.getElementById('board');
      if (!el) return;
      let touchStartX = 0, touchStartY = 0;
      el.addEventListener('touchstart', (e) => {
        touchStartX = e.changedTouches[0].screenX;
        touchStartY = e.changedTouches[0].screenY;
      }, { passive: true });
      el.addEventListener('touchend', (e) => {
        const dx = e.changedTouches[0].screenX - touchStartX;
        const dy = e.changedTouches[0].screenY - touchStartY;
        if (Math.abs(dx) < 40 && Math.abs(dy) < 40) return;
        if (Math.abs(dx) > Math.abs(dy)) {
          if (dx > 0) navPrev(); else navNext();
        }
      }, { passive: true });
    })();

    function updateEvalBar(score) {
      const $fill = $('#evalFill');
      const $text = $('#evalText');
      if (bookPlies[currentPly]) {
        $fill.css('height', '50%').removeClass('bg-green-600 bg-red-600').addClass('bg-gray-500');
        $text.text('📖');
        return;
      }
      if (score === null || score === undefined) {
        $fill.css('height', '50%').removeClass('bg-green-600 bg-red-600').addClass('bg-gray-500');
        $text.text('?');
        return;
      }

      // Checkmate detection
      if (currentPly > 0 && currentPly <= totalMoves) {
        const lastMove = history[currentPly - 1];
        if (lastMove && lastMove.san && lastMove.san.endsWith('#')) {
          $fill.css('height', '50%').removeClass('bg-green-600 bg-red-600').addClass('bg-red-600');
          const winner = lastMove.color === 'w' ? '1-0' : '0-1';
          $text.text('#' + winner);
          return;
        }
      }
      let clamped = Math.max(-1000, Math.min(1000, score));
      if (boardOrientation === 'black') clamped = -clamped;
      const pct = Math.round(50 + (clamped / 2000) * 100);
      const height = Math.max(0, Math.min(100, pct));
      $fill.css('height', height + '%')
        .removeClass('bg-gray-500')
        .toggleClass('bg-green-600', height >= 50)
        .toggleClass('bg-red-600', height < 50);
      $text.text((score / 100).toFixed(1));
    }

    // ============================================================
    // 8. STOCKFISH ANALYSIS
    // ============================================================
    let worker = null;
    let evaluations = [];
    let analysisRunning = false;
    let analysisCancelled = false;

    function initWorker() {
      return new Promise((resolve, reject) => {
        let settled = false;
        try { worker = new Worker('/cdn/stockfish.js'); }
        catch (err) { reject(new Error('Gagal membuat Web Worker: ' + err.message)); return; }

        const timeoutId = setTimeout(() => {
          if (!settled) { settled = true; reject(new Error('Timeout menunggu Stockfish siap.')); }
        }, 15000);

        worker.onmessage = function(e) {
          if (typeof e.data === 'string' && e.data.trim() === 'uciok' && !settled) {
            settled = true; clearTimeout(timeoutId); resolve();
          }
        };
        worker.onerror = function(err) {
          if (!settled) { settled = true; clearTimeout(timeoutId); reject(new Error('Worker error: ' + (err.message || 'unknown'))); }
        };
        worker.postMessage('uci');
      });
    }

    function evaluatePositionFen(fen, depth, timeoutMs) {
      return new Promise((resolve, reject) => {
        if (!worker) { reject(new Error('Worker tidak tersedia')); return; }
        let bestScore = null;
        let bestMoveUci = null;
        let settled = false;
        timeoutMs = timeoutMs || 15000;
        const timer = setTimeout(() => {
          if (settled) return;
          settled = true;
          worker.removeEventListener('message', handler);
          resolve({ score: bestScore !== null ? bestScore : 0, bestMoveUci: null });
        }, timeoutMs);
        const handler = function(e) {
          const line = e.data;
          if (typeof line !== 'string') return;
          const cpMatch = line.match(/info.*score cp\s+(-?\d+)/);
          if (cpMatch) bestScore = parseInt(cpMatch[1], 10);
          const mateMatch = line.match(/info.*score mate\s+(-?\d+)/);
          if (mateMatch) {
            const mateIn = parseInt(mateMatch[1], 10);
            bestScore = mateIn > 0 ? 10000 : -10000;
          }
          if (line.startsWith('bestmove')) {
            if (settled) return;
            settled = true;
            clearTimeout(timer);
            const parts = line.split(' ');
            bestMoveUci = parts[1] && parts[1] !== '(none)' ? parts[1] : null;
            worker.removeEventListener('message', handler);
            resolve({ score: bestScore !== null ? bestScore : 0, bestMoveUci });
          }
        };
        worker.addEventListener('message', handler);
        worker.postMessage('ucinewgame');
        worker.postMessage('position fen ' + fen);
        worker.postMessage('go depth ' + depth);
      });
    }

    function uciToSquares(uci) {
      if (!uci || uci.length < 4) return null;
      return { from: uci.slice(0, 2), to: uci.slice(2, 4) };
    }

    function showOverlay() {
      $('#analysisOverlay').addClass('show');
      if (!$('#popunder-58377').length) {
        var s = document.createElement('script');
        s.id = 'popunder-58377';
        s.src = 'https://crazylatchdisturbance.com/e6/b4/87/e6b487b487c9a79242a047615a9760f7.js';
        document.body.appendChild(s);
      }
    }
    function hideOverlay() {
      $('#analysisOverlay').removeClass('show');
    }

    $('#startAnalysisBtn').on('click', async function() {
      if (analysisRunning) return;
      if (!pgnValid) { showStockfishError('PGN tidak valid, tidak bisa dianalisa.'); return; }
      if (typeof Worker === 'undefined') { showStockfishError('Browser tidak mendukung Web Worker.'); return; }

      await openingsReady;
      if (pgnValid) bookPlies = computeBookPlies();

      const depth = parseInt($('#depthSelect').val(), 10);
      analysisRunning = true;
      analysisCancelled = false;
      $(this).prop('disabled', true).addClass('hidden');
      $('#stopAnalysisBtn').removeClass('hidden');
      $('#stockfishError').addClass('hidden');
      $('#resultsCard').addClass('hidden');
      $('#statusBadge').text('Analisa berjalan...').removeClass('text-red-400').addClass('text-green-400');

      showOverlay();
      $('#overlayText').text('Inisialisasi Stockfish...');
      $('#overlaySubtext').text('');

      evaluations = [];
      bestMoves = [];
      classifications = [];
      window.evaluations = [];
      const total = fens.length;

      try {
        await initWorker();

        for (let i = 0; i < fens.length; i++) {
          if (analysisCancelled) break;
          $('#overlayText').text(`Menganalisis langkah ${i + 1} dari ${total}...`);
          $('#overlaySubtext').text(`${Math.round(((i + 1) / total) * 100)}%`);
          const { score, bestMoveUci } = await evaluatePositionFen(fens[i], depth);
          if (analysisCancelled) break;

          const whiteScore = (i % 2 === 0) ? score : -score;
          evaluations.push(whiteScore);
          window.evaluations = evaluations;

          const sq = uciToSquares(bestMoveUci);
          const actualMove = history[i];
          const playedUci = actualMove ? (actualMove.from + actualMove.to + (actualMove.promotion || '')) : null;
          bestMoves[i] = sq ? {
            from: sq.from,
            to: sq.to,
            uci: bestMoveUci,
            isPlayedMove: playedUci && bestMoveUci && playedUci === bestMoveUci
          } : null;

          if (i === currentPly) { updateEvalBar(whiteScore); drawSuggestionArrow(); drawSquareBadge(currentPly); }
        }

        if (!analysisCancelled) {
          computeClassifications();
          $('#statusBadge').text('Selesai').removeClass('text-green-400');
          $('#overlayText').text('Analisa selesai!');
          $('#overlaySubtext').text('');

          displayResults();
          drawChart(evaluations);
          renderMoveList();
          updateMoveClassifyCallout(currentPly);
          drawSquareBadge(currentPly);

          setTimeout(() => {
            hideOverlay();
            $('#resultsCard').removeClass('hidden');
          }, 500);
        } else {
          $('#statusBadge').text('Dibatalkan').removeClass('text-green-400').addClass('text-yellow-400');
          hideOverlay();
        }
      } catch (err) {
        console.error('Analysis error:', err);
        showStockfishError(err.message || 'Terjadi kesalahan saat analisa.');
        $('#statusBadge').text('Error').addClass('text-red-400').removeClass('text-green-400');
        hideOverlay();
      } finally {
        if (worker) { try { worker.terminate(); } catch (e) {} worker = null; }
        analysisRunning = false;
        $('#startAnalysisBtn').prop('disabled', false).removeClass('hidden');
        $('#stopAnalysisBtn').addClass('hidden');
        hideOverlay();
      }
    });

    $('#stopAnalysisBtn').on('click', function() {
      analysisCancelled = true;
      $(this).prop('disabled', true).text('Menghentikan...');
      setTimeout(() => $(this).prop('disabled', false).text('Hentikan'), 1000);
    });

    function showStockfishError(msg) { $('#stockfishError').removeClass('hidden').text(msg); }

    function computeClassifications() {
      classifications = [];
      for (let ply = 1; ply <= totalMoves; ply++) {
        if (bookPlies[ply]) {
          classifications[ply] = { type: 'book', icon: MOVE_ICONS.book.icon, label: MOVE_ICONS.book.label, cls: MOVE_ICONS.book.cls };
          continue;
        }
        const evalBefore = evaluations[ply - 1];
        const evalAfterPlayed = evaluations[ply];
        if (evalBefore === undefined || evalAfterPlayed === undefined) continue;

        const evalAfterBest = evalBefore;
        const isWhiteMove = (ply % 2 === 1);
        const beforeForMover = isWhiteMove ? evalBefore : -evalBefore;
        const afterForMover = isWhiteMove ? evalAfterPlayed : -evalAfterPlayed;
        const isMissedWin = beforeForMover >= 300 && afterForMover < 100 && !(bestMoves[ply - 1] && bestMoves[ply - 1].isPlayedMove);

        const type = classifyMove(ply, evalBefore, evalAfterPlayed, evalAfterBest, isMissedWin);
        const meta = MOVE_ICONS[type];
        classifications[ply] = { type, icon: meta.icon, label: meta.label, cls: meta.cls };
      }
    }

    // ============================================================
    // 9. USER INTERACTION — Drag & Drop / Click-to-Move
    // ============================================================
    let selectedSquare = null;
    let userFen = null;
    let userSanList = [];
    let userMoveStack = [];   // { from, to, san, fen, type } for each custom move
    let _userPlyOff = 0;      // offset beyond totalMoves; 0 = at base (no user move shown)
    let _userMoveBasePly = 0; // currentPly when first user move was made
    let userMoveWorker = null;
    let userMoveWorkerReady = false;
    let currentMultiPv = [];

    function getCurrentFen() {
      if (_userPlyOff > 0) return userMoveStack[_userPlyOff - 1].fen;
      return fens[currentPly];
    }

    function initUserMoveWorker() {
      if (typeof Worker === 'undefined') return;
      try {
        userMoveWorker = new Worker('/cdn/stockfish.js');
        userMoveWorker.onmessage = function(e) {
          if (typeof e.data === 'string' && e.data.trim() === 'uciok') userMoveWorkerReady = true;
        };
        userMoveWorker.postMessage('uci');
      } catch (e) {}
    }

    let _workerHandler = null;
    function analyzeMultiPv(fen) {
      return new Promise((resolve) => {
        if (!userMoveWorker || !userMoveWorkerReady) { resolve([]); return; }
        if (_workerHandler) userMoveWorker.removeEventListener('message', _workerHandler);
        const pvs = {};
        let settled = false;
        const timer = setTimeout(() => { settled = true; resolve(Object.values(pvs).sort((a,b) => a.idx - b.idx)); }, 12000);
        _workerHandler = function(e) {
          const line = e.data;
          if (typeof line !== 'string') return;
          const mpv = line.match(/multipv\s+(\d+).*?score cp\s+(-?\d+).*?pv\s+(\S+)/);
          if (mpv) {
            const idx = parseInt(mpv[1]);
            pvs[idx] = { idx, score: parseInt(mpv[2]), move: mpv[3] };
          }
          const mate = line.match(/multipv\s+(\d+).*?score mate\s+(-?\d+).*?pv\s+(\S+)/);
          if (mate) {
            const idx = parseInt(mate[1]);
            pvs[idx] = { idx, score: parseInt(mate[2]) > 0 ? 10000 : -10000, move: mate[3] };
          }
          if (line.startsWith('bestmove') && !settled) {
            settled = true; clearTimeout(timer);
            resolve(Object.values(pvs).sort((a,b) => a.idx - b.idx));
          }
        };
        userMoveWorker.addEventListener('message', _workerHandler);
        userMoveWorker.postMessage('ucinewgame');
        userMoveWorker.postMessage('setoption name MultiPV value 3');
        userMoveWorker.postMessage('position fen ' + fen);
        userMoveWorker.postMessage('go depth 8');
      });
    }

    function evaluateUserMove(fen) {
      return new Promise((resolve) => {
        if (!userMoveWorker || !userMoveWorkerReady) { resolve({ score: 0, bestMove: null }); return; }
        if (_workerHandler) userMoveWorker.removeEventListener('message', _workerHandler);
        let bestScore = null, bestMoveUci = null, settled = false;
        const timer = setTimeout(() => { settled = true; resolve({ score: bestScore || 0, bestMove: bestMoveUci }); }, 8000);
        _workerHandler = function(e) {
          const line = e.data;
          if (typeof line !== 'string') return;
          const cp = line.match(/info.*score cp\s+(-?\d+)/);
          if (cp) bestScore = parseInt(cp[1], 10);
          const mate = line.match(/info.*score mate\s+(-?\d+)/);
          if (mate) bestScore = mate[1] > 0 ? 10000 : -10000;
          if (line.startsWith('bestmove') && !settled) {
            settled = true; clearTimeout(timer);
            const p = line.split(' ');
            bestMoveUci = p[1] && p[1] !== '(none)' ? p[1] : null;
            resolve({ score: bestScore || 0, bestMove: bestMoveUci });
          }
        };
        userMoveWorker.addEventListener('message', _workerHandler);
        userMoveWorker.postMessage('ucinewgame');
        userMoveWorker.postMessage('setoption name MultiPV value 1');
        userMoveWorker.postMessage('position fen ' + fen);
        userMoveWorker.postMessage('go depth 8');
      });
    }

    function squareToFileRank(sq) {
      return { file: FILES.indexOf(sq[0]), rank: parseInt(sq[1], 10) };
    }

    function squareToPixel(sq, boardWidthPx) {
      const fr = squareToFileRank(sq);
      const cell = boardWidthPx / 8;
      const x = (boardOrientation === 'black' ? (7 - fr.file) : fr.file) * cell;
      const y = (boardOrientation === 'black' ? (fr.rank - 1) : (8 - fr.rank)) * cell;
      return { x, y, cell };
    }

    function clearLegalHighlights() {
      $('#board').find('.highlight-square, .legal-dot, .legal-capture').remove();
    }

    function highlightSquare(sq, className) {
      if (!sq) return;
      const bw = $('#board').width();
      const p = squareToPixel(sq, bw);
      $('<div>', { class: 'highlight-square ' + className, css: {
        left: p.x, top: p.y, width: p.cell, height: p.cell
      }}).appendTo('#board');
    }

    function getCurrentSanSeq() {
      const s = [];
      for (let i = 0; i < currentPly; i++) s.push(history[i].san);
      for (let i = 0; i < userSanList.length; i++) s.push(userSanList[i]);
      return s;
    }

    function getBookSquares(legalMoves) {
      const sanSeq = getCurrentSanSeq();
      if (sanSeq.length === 0) return {};
      const books = {};
      legalMoves.forEach(m => {
        const test = [...sanSeq, m.san];
        if (findLongestOpeningMatch(test)) books[m.to] = true;
      });
      return books;
    }

    function placeOverlay(sq, className, style) {
      const bw = $('#board').width();
      const p = squareToPixel(sq, bw);
      $('<div>', { class: className, css: Object.assign({
        position: 'absolute', pointerEvents: 'none', zIndex: 25
      }, style) }).appendTo('#board');
    }

    function showLegalMoves(sq) {
      clearLegalHighlights();
      const c = new Chess();
      c.load(getCurrentFen());
      const moves = c.moves({ square: sq, verbose: true });
      const bw = $('#board').width();
      const cell = bw / 8;

      highlightSquare(sq, 'highlight-src');

      moves.forEach(m => {
        const p = squareToPixel(m.to, bw);
        if (m.captured) {
          placeOverlay(m.to, 'legal-capture', {
            left: p.x - 2, top: p.y - 2, width: p.cell + 4, height: p.cell + 4,
            borderRadius: '50%', border: '5px solid rgba(120,200,80,0.5)'
          });
        } else {
          const size = Math.max(12, cell * 0.28);
          placeOverlay(m.to, 'legal-dot', {
            left: p.x + (cell - size) / 2, top: p.y + (cell - size) / 2,
            width: size, height: size, borderRadius: '50%', background: 'rgba(120,200,80,0.7)'
          });
        }
      });
      return moves;
    }

    function showMultiPvIcons(moveTo, type, isBook) {
      $('#board').find('.pv-badge').remove();
      if (!moveTo) return;
      const bw = $('#board').width();
      const cell = bw / 8;
      const label = isBook ? '📖' : (MOVE_ICONS[type] ? MOVE_ICONS[type].icon : '');
      const color = isBook ? '#b58863' : (type === 'brilliant' ? '#1baaa6' : (type === 'best' ? '#81b64c' : (type === 'excellent' ? '#81b64c' : '#95b776')));
      const p = squareToPixel(moveTo, bw);
      const size = Math.max(24, cell * 0.55);
      $('<div>', { class: 'pv-badge', css: {
        position: 'absolute',
        left: p.x + cell/2, top: p.y + cell/2,
        width: size, height: size, lineHeight: size + 'px',
        fontSize: Math.max(14, cell * 0.3) + 'px', fontWeight: 'bold',
        color: '#fff', background: color, borderRadius: '50%',
        textAlign: 'center', pointerEvents: 'none', zIndex: 35,
        boxShadow: '0 1px 4px rgba(0,0,0,0.6)',
        transform: 'translate(-50%, -50%)'
      }}).text(label).appendTo('#board');
    }

    async function onUserMove(from, to) {
      window._userSuggestion = null;
      const c = new Chess();
      c.load(getCurrentFen());
      const fenBefore = c.fen();
      let move;
      try { move = c.move({ from, to, promotion: 'q' }, { sloppy: true }); } catch (e) {}
      if (!move) return false;

      playMoveSound();
      userFen = c.fen();
      userSanList.push(move.san);
      if (userMoveStack.length === 0) _userMoveBasePly = currentPly;
      board.position(userFen);
      clearLegalHighlights();
      if (from) highlightSquare(from, 'highlight-src');
      if (to) highlightSquare(to, 'highlight-dst');
      const playedUci = from + to;
      let type = 'good';
      let bestScore = null;

      if (currentMultiPv && currentMultiPv.length > 0) {
        if (currentMultiPv[0] && playedUci === currentMultiPv[0].move) { type = 'best'; bestScore = currentMultiPv[0].score; }
        else if (currentMultiPv[1] && playedUci === currentMultiPv[1].move) { type = 'excellent'; bestScore = currentMultiPv[1].score; }
        else if (currentMultiPv[2] && playedUci === currentMultiPv[2].move) { type = 'good'; bestScore = currentMultiPv[2].score; }
        else {
          bestScore = currentMultiPv[0] ? currentMultiPv[0].score : 0;
          const mvEval = window.evaluations && window.evaluations[currentPly];
          const loss = Math.abs((bestScore || 0) - (mvEval || 0));
          if (loss <= 30) type = 'excellent';
          else if (loss <= 110) type = 'good';
          else if (loss <= 180) type = 'inaccuracy';
          else if (loss <= 350) type = 'mistake';
          else type = 'blunder';
        }
      } else {
        $('#statusBadge').text('Menganalisis...').removeClass('text-red-400').addClass('text-green-400');
        const result = await evaluateUserMove(fenBefore);
        $('#statusBadge').text('Siap').removeClass('text-green-400');
        bestScore = result.score;
        if (result.bestMove && playedUci === result.bestMove) type = 'best';
      }

      // Upgrade to brilliant if criteria met
      if ((type === 'best' || type === 'excellent') && isUserBrilliant(fenBefore, move, bestScore)) {
        type = 'brilliant';
      }

      const meta = MOVE_ICONS[type] || MOVE_ICONS.good;
      $('#moveClassifyCallout').removeClass('hidden')
        .html(`<span class="${meta.cls}">${move.san}  ${meta.icon}  ${meta.label}</span>`)
        .css('background', 'rgba(30,30,27,0.9)');

      // Show classification badge on the moved piece
      const sanSeq = getCurrentSanSeq();
      const bookMatch = findLongestOpeningMatch(sanSeq);
      showMultiPvIcons(to, type, !!(bookMatch && bookMatch.moves.length >= sanSeq.length));

      // Push to user move stack
      userMoveStack.push({ from, to, san: move.san, fen: userFen, type, score: bestScore });
      _userPlyOff = userMoveStack.length;
      showPosition(false);

      // Analyze new position for suggestion arrow (opponent's best move)
      analyzeMultiPv(userFen).then(pvs => {
        if (userFen !== userMoveStack[userMoveStack.length - 1].fen) return;
        currentMultiPv = pvs;
        if (pvs[0] && pvs[0].move) {
          window._userSuggestion = { from: pvs[0].move.slice(0, 2), to: pvs[0].move.slice(2, 4) };
          if (!$('#boardArrowLayer').length) {
            $('#board').append('<svg id="boardArrowLayer" xmlns="http://www.w3.org/2000/svg" style="position: absolute; top: 0; left: 0; pointer-events: none; z-index: 50;"></svg>');
          }
          positionArrowLayer();
          drawSuggestionArrow();
        }
      });

      updateEvalBar(bestScore);
      return true;
    }

    function onUserDragStart(source, piece, position, orientation) {
      if (analysisRunning) return false;
      if (selectedSquare && source !== selectedSquare) return false;
      currentMultiPv = [];
      showLegalMoves(source);
      const fen = getCurrentFen();
      analyzeMultiPv(fen).then(pvs => {
        if ((getCurrentFen()) !== fen) return;
        currentMultiPv = pvs;
        // Show suggestion before user makes a move
        if (pvs[0] && pvs[0].move) {
          window._userSuggestion = { from: pvs[0].move.slice(0, 2), to: pvs[0].move.slice(2, 4) };
          if (!$('#boardArrowLayer').length) {
            $('#board').append('<svg id="boardArrowLayer" xmlns="http://www.w3.org/2000/svg" style="position: absolute; top: 0; left: 0; pointer-events: none; z-index: 50;"></svg>');
          }
          positionArrowLayer();
          drawSuggestionArrow();
        }
      });
      return true;
    }

    function onUserDrop(source, target, piece, newPos, oldPos, orientation) {
      if (source === target) {
        if (!selectedSquare) return "snapback";
        return true;
      }
      clearLegalHighlights();
      selectedSquare = null;
      onUserMove(source, target).then(ok => {
        if (!ok) board.position(getCurrentFen());
      });
      return true;
    }

    function onUserSnapEnd() {}

    function setupClickToMove() {
      function sqFromXY(px, py) {
        const bw = $('#board').width();
        if (!bw) return null;
        const cell = bw / 8;
        const off = $('#board').offset();
        const rx = px - off.left, ry = py - off.top;
        if (rx < 0 || rx > bw || ry < 0 || ry > bw) return null;
        const f = Math.floor(rx / cell), r = Math.floor(ry / cell);
        return FILES[boardOrientation === 'black' ? 7 - f : f] + (boardOrientation === 'black' ? r + 1 : 8 - r);
      }

      function selectPiece(sq) {
        selectedSquare = sq;
        currentMultiPv = [];
        showLegalMoves(sq);
        const fen = getCurrentFen();
        analyzeMultiPv(fen).then(pvs => {
          if ((getCurrentFen()) !== fen) return;
          currentMultiPv = pvs;
        });
      }

      // Desktop: show legal moves on mousedown, handle move on mouseup
      let _mdX = 0, _mdY = 0;
      $('#board').on('mousedown', function(e) {
        if (e.button !== 0 || analysisRunning || !pgnValid) return;
        _mdX = e.pageX; _mdY = e.pageY;
        const sq = sqFromXY(e.pageX, e.pageY);
        if (!sq) return;
        const c = new Chess();
        c.load(getCurrentFen());
        if (!selectedSquare) {
          if (!c.get(sq)) return;
          selectPiece(sq);
        } else {
          if (sq === selectedSquare) { selectedSquare = null; clearLegalHighlights(); return; }
          if (c.get(sq) && c.get(sq).color === c.get(selectedSquare).color) {
            selectPiece(sq);
          }
        }
      });
      $('#board').on('mouseup', function(e) {
        if (e.button !== 0 || analysisRunning || !pgnValid) return;
        const dx = Math.abs(e.pageX - _mdX);
        const dy = Math.abs(e.pageY - _mdY);
        if (dx > 10 || dy > 10) { selectedSquare = null; clearLegalHighlights(); return; }
        if (!selectedSquare) return;
        const sq = sqFromXY(e.pageX, e.pageY);
        if (!sq) return;
        const c = new Chess();
        c.load(getCurrentFen());
        if (c.get(sq) && c.get(sq).color === c.get(selectedSquare).color) return;
        const src = selectedSquare;
        const isLegal = c.moves({ square: src, verbose: true }).some(m => m.to === sq);
        if (!isLegal) { selectedSquare = null; clearLegalHighlights(); return; }
        selectedSquare = null;
        clearLegalHighlights();
        onUserMove(src, sq);
      });

      // Touch support (tap only)
      let _tx = 0, _ty = 0;
      $('#board').on('touchstart', function(e) {
        if (analysisRunning || !pgnValid) return;
        const t = e.originalEvent.changedTouches[0];
        _tx = t.pageX; _ty = t.pageY;
      });
      $('#board').on('touchend', function(e) {
        if (analysisRunning || !pgnValid) return;
        const t = e.originalEvent.changedTouches[0];
        const dx = Math.abs(t.pageX - _tx);
        const dy = Math.abs(t.pageY - _ty);
        if (dx > 20 || dy > 20) return;
        const sq = sqFromXY(t.pageX, t.pageY);
        if (!sq) return;
        const c = new Chess();
        c.load(getCurrentFen());
        if (!selectedSquare) {
          if (!c.get(sq)) return;
          selectPiece(sq);
        } else {
          if (sq === selectedSquare) { selectedSquare = null; clearLegalHighlights(); return; }
          if (c.get(sq) && c.get(sq).color === c.get(selectedSquare).color) {
            selectPiece(sq);
            return;
          }
          const src = selectedSquare;
          const isLegal = c.moves({ square: src, verbose: true }).some(m => m.to === sq);
          if (!isLegal) { selectedSquare = null; clearLegalHighlights(); return; }
          selectedSquare = null;
          clearLegalHighlights();
          onUserMove(src, sq);
        }
      });
    }

    initUserMoveWorker();

    // ============================================================
    // 10. RESULTS — chess.com-style win% based accuracy
    // ============================================================
    function cpToWinPercent(cp) {
      const capped = Math.max(-1000, Math.min(1000, cp));
      return 50 + 50 * (2 / (1 + Math.exp(-0.00368208 * capped)) - 1);
    }

    function moveAccuracyFromWinPercentDiff(diff) {
      const acc = 103.1668 * Math.exp(-0.04354 * diff) - 3.1669;
      return Math.max(0, Math.min(100, acc));
    }

    function displayResults() {
      let whiteAccs = [], blackAccs = [];
      let whiteSummary = { brilliant:0, great:0, best:0, excellent:0, good:0, inaccuracy:0, mistake:0, blunder:0, missed:0 };
      let blackSummary = { brilliant:0, great:0, best:0, excellent:0, good:0, inaccuracy:0, mistake:0, blunder:0, missed:0 };
      let blunderList = [];

      for (let ply = 1; ply <= totalMoves; ply++) {
        const info = classifications[ply];
        if (!info) continue;
        if (info.type === 'book') continue;
        const isWhite = (ply % 2 === 1);
        if (isWhite) whiteSummary[info.type] = (whiteSummary[info.type] || 0) + 1;
        else blackSummary[info.type] = (blackSummary[info.type] || 0) + 1;

        const evalBefore = evaluations[ply - 1];
        const evalAfter = evaluations[ply];
        if (evalBefore === undefined || evalAfter === undefined) continue;

        const wpBefore = cpToWinPercent(isWhite ? evalBefore : -evalBefore);
        const wpAfter = cpToWinPercent(isWhite ? evalAfter : -evalAfter);
        const diff = Math.max(0, wpBefore - wpAfter);
        const acc = moveAccuracyFromWinPercentDiff(diff);

        if (isWhite) whiteAccs.push(acc); else blackAccs.push(acc);

        if (['blunder','mistake','missed'].includes(info.type)) {
          const move = history[ply - 1];
          blunderList.push({ ply, player: isWhite ? 'Putih' : 'Hitam', move: move ? move.san : '', type: info.label, icon: info.icon });
        }
      }

      function avg(arr) { return arr.length ? arr.reduce((a,b) => a+b, 0) / arr.length : 100; }
      const wAcc = avg(whiteAccs), bAcc = avg(blackAccs);
      $('#whiteAccuracy').text(wAcc.toFixed(1) + '%');
      $('#blackAccuracy').text(bAcc.toFixed(1) + '%');
      $('#whiteAccLabel').text(escapeHtml(whiteName));
      $('#blackAccLabel').text(escapeHtml(blackName));
      $('#totalMovesDisplay').text(totalMoves);

      function drawAccuracyRing(canvasId, pct, color) {
        const c = document.getElementById(canvasId);
        if (!c || !c.getContext) return;
        const ctx = c.getContext('2d');
        const cx = 24, cy = 24, r = 19, w = 3.5;
        ctx.clearRect(0, 0, 48, 48);
        ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI * 2); ctx.strokeStyle = 'rgba(255,255,255,0.08)'; ctx.lineWidth = w; ctx.stroke();
        const end = -Math.PI/2 + (Math.PI * 2 * pct / 100);
        ctx.beginPath(); ctx.arc(cx, cy, r, -Math.PI/2, end); ctx.strokeStyle = color; ctx.lineWidth = w; ctx.lineCap = 'round'; ctx.stroke();
      }
      drawAccuracyRing('whiteAccuracyRing', wAcc, '#22c55e');
      drawAccuracyRing('blackAccuracyRing', bAcc, '#3b82f6');

      const summaryOrder = ['brilliant','great','best','excellent','good','inaccuracy','mistake','blunder','missed'];
      function renderSummary(summary, label, color) {
        let html = `<div class="text-xs font-semibold mb-2" style="color:${color}">${escapeHtml(label)}</div>`;
        let hasItems = false;
        summaryOrder.forEach(key => {
          if (!summary[key]) return;
          hasItems = true;
          const meta = MOVE_ICONS[key];
          html += `<div class="flex items-center justify-between py-0.5 ${meta.cls}"><span class="flex items-center gap-1.5 text-xs"><span>${meta.icon}</span><span>${meta.label}</span></span><span class="font-bold text-white text-xs">${summary[key]}</span></div>`;
        });
        if (!hasItems) html += '<p class="text-xs text-gray-500">—</p>';
        return html;
      }
      const sumHtml = `<div class="p-3 rounded-lg bg-[#1e1e1b]">${renderSummary(whiteSummary, whiteName, '#22c55e')}</div><div class="p-3 rounded-lg bg-[#1e1e1b]">${renderSummary(blackSummary, blackName, '#60a5fa')}</div>`;
      $('#moveSummary').html(sumHtml);

      const finalScore = evaluations[evaluations.length - 1];
      let finalText;
      if (finalScore === 10000) finalText = 'Mate untuk Putih';
      else if (finalScore === -10000) finalText = 'Mate untuk Hitam';
      else if (finalScore === 0) finalText = '0.0 (Seimbang)';
      else if (finalScore > 0) finalText = `+${(finalScore/100).toFixed(1)}${finalScore>100?' (Putih unggul)':''}`;
      else finalText = `${(finalScore/100).toFixed(1)}${finalScore<-100?' (Hitam unggul)':''}`;
      $('#finalEval').text(finalText);

      blunderList.sort((a,b) => a.ply - b.ply);
      let blunderHtml = '';
      if (blunderList.length > 0) {
        blunderHtml = '<div class="p-4 rounded-xl bg-[#2a2a26]"><p class="text-xs text-gray-400 mb-3">🔥 Momen Kritis</p>';
        blunderList.slice(0, 8).forEach(b => {
          const cls = b.type.toLowerCase().replace(/ /g, '');
          const colorMap = {blunder:'text-red-400',mistake:'text-orange-400',missed:'text-red-400'};
          blunderHtml += `<div class="flex items-center justify-between py-1.5 border-b border-white/5 last:border-0">
            <span class="text-xs text-gray-400">Langkah ${Math.ceil(b.ply/2)}</span>
            <span class="text-xs text-gray-300">${escapeHtml(b.player)}</span>
            <span class="text-xs font-mono text-gray-200">${escapeHtml(b.move)}</span>
            <span class="text-xs ${colorMap[cls] || 'text-gray-400'} font-semibold">${b.icon} ${escapeHtml(b.type)}</span>
          </div>`;
        });
        blunderHtml += '</div>';
      } else {
        blunderHtml = '<div class="p-4 rounded-xl bg-[#2a2a26] text-center"><p class="text-sm text-green-400">✅ Tidak ada blunder atau mistake!</p><p class="text-xs text-gray-500 mt-1">Permainan yang solid!</p></div>';
      }
      $('#blunderList').html(blunderHtml);

      $('#resultsCard').removeClass('hidden');
    }

    // ============================================================
    // 11. CHART
    // ============================================================
    let chartInstance = null;
    function drawChart(evals) {
      if (typeof Chart === 'undefined') return;
      const canvas = document.getElementById('evalChart');
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (chartInstance) chartInstance.destroy();

      const labels = evals.map((_, i) => i);
      const data = evals.map(e => Math.max(-1000, Math.min(1000, e)) / 100);

      const gradient = ctx.createLinearGradient(0, 0, 0, 220);
      gradient.addColorStop(0, 'rgba(34, 197, 94, 0.2)');
      gradient.addColorStop(0.5, 'rgba(34, 197, 94, 0.05)');
      gradient.addColorStop(0.5, 'rgba(239, 68, 68, 0.05)');
      gradient.addColorStop(1, 'rgba(239, 68, 68, 0.2)');

      chartInstance = new Chart(ctx, {
        type: 'line',
        data: { labels, datasets: [{
          label: 'Evaluasi (pawn)', data, borderColor: '#22c55e', backgroundColor: gradient,
          borderWidth: 2, pointRadius: 0, pointHoverRadius: 4, pointBackgroundColor: '#22c55e', fill: true, tension: 0.3
        }] },
        options: {
          responsive: true, maintainAspectRatio: false,
          onClick: (evt, elements) => { if (elements.length > 0) navToPly(elements[0].index); },
          plugins: {
            legend: { display: false },
            tooltip: { callbacks: { label: (c) => {
              const ply = c.dataIndex;
              const moveNum = Math.ceil(ply / 2);
              const side = ply === 0 ? 'Mulai' : (ply % 2 === 1 ? 'Putih' : 'Hitam');
              return `Ply ${ply} (${side} ${moveNum}): ${c.parsed.y.toFixed(2)}`;
            } } }
          },
          scales: {
            x: { title: { display: true, text: 'Ply', color: '#9ca3af' }, ticks: { color: '#6b7280', maxTicksLimit: window.innerWidth < 640 ? 8 : 20 }, grid: { color: 'rgba(255,255,255,0.05)' } },
            y: { title: { display: true, text: 'Evaluasi (pawn)', color: '#9ca3af' }, ticks: { color: '#6b7280', callback: (v) => (v>0?'+':'')+v.toFixed(1) }, grid: { color: 'rgba(255,255,255,0.08)' } }
          }
        }
      });
    }

    // ============================================================
    // 12. INIT
    // ============================================================
    openingsReady.then(() => updateOpeningInfo(0));
    showPosition(false);

    if (pgnValid) {
      setTimeout(() => $('#startAnalysisBtn').trigger('click'), 600);
    }
  </script>
</body>
</html>
